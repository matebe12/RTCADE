# Frontend (Vercel) — set these in Vercel dashboard
VITE_API_URL=https://your-railway-app.up.railway.app
VITE_WS_URL=wss://your-railway-app.up.railway.app

# Monitoring (Vercel)
VITE_AMPLITUDE_API_KEY=your-amplitude-api-key
VITE_SENTRY_DSN=https://xxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx
VITE_APP_ENV=production
# VITE_SENTRY_RELEASE=1.0.0  # optional, auto-detected from git if omitted
VITE_ENABLE_SIDE_ADS=true
VITE_AD_PROVIDER=coupang
VITE_AD_DESKTOP_MIN_WIDTH=1536
VITE_AD_RIGHT_RAIL_MIN_WIDTH=1280
VITE_AD_DISCLOSURE_TEXT=광고
VITE_AD_LEFT_SLOT_ID=983965
VITE_AD_RIGHT_SLOT_ID=983966
VITE_COUPANG_TRACKING_CODE=AF8859609
VITE_COUPANG_SUB_ID=
VITE_COUPANG_TEMPLATE=carousel
VITE_COUPANG_RAIL_WIDTH=180
VITE_COUPANG_RAIL_HEIGHT=600
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_TEST_MODE=true

# Sentry source map upload — Vercel build environment only
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=rtcade
SENTRY_PROJECT=rtcade

# Backend (Railway) — set these in Railway dashboard
PORT=3001
CORS_ORIGIN=https://your-vercel-app.vercel.app
ROMS_PATH=/app/server/roms

# Sentry backend (Railway)
SENTRY_DSN=https://xxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# Backend DB (Railway Postgres)
# Railway backend service should prefer the internal URL.
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# Local/manual connection from your machine should use the public URL.
DATABASE_PUBLIC_URL=postgresql://postgres:password@public-host:port/railway?sslmode=require

# Or use individual values if you are wiring them manually
PGHOST=postgres.railway.internal
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=password
PGSSLMODE=disable

# Optional admin write API for notices
NOTICE_ADMIN_TOKEN=replace-with-a-strong-random-token

# ICE / TURN servers (optional)
# STUN_SERVER_URLS=stun:stun.l.google.com:19302
# TURN_SERVER_URLS=turn:your-turn-server.example.com:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=
